# Postgres connection string used by the running app.
# For Neon (or any PgBouncer-fronted Postgres), use the POOLED host — the one
# with "-pooler" in the hostname.
#
# Recommended starting points:
# - Local dev / single-process load tests: connection_limit=10
# - Vercel production: start around connection_limit=1..2 per function and
#   monitor saturation in /api/admin/health
#
# This example is intentionally local-dev friendly.
DATABASE_URL="postgresql://user:pass@HOST-pooler.REGION.aws.neon.tech/db?pgbouncer=true&connection_limit=10&sslmode=require"

# Direct (non-pooled) Postgres URL — required by `prisma migrate dev/deploy`
# because PgBouncer in transaction mode doesn't support the prepared
# statements/locks Prisma uses for migrations. Use the same DB but the host
# WITHOUT "-pooler". If unset, Prisma falls back to DATABASE_URL.
DIRECT_URL="postgresql://user:pass@HOST.REGION.aws.neon.tech/db?sslmode=require"

# Session signing secret — generate with:
#   node -e "const {randomBytes}=require('crypto');console.log(randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-random-64-hex-char-string"

# OpenAI — leave empty to use built-in fallback quizzes for local testing
OPENAI_API_KEY=""

# Optional: override quiz model (default: gpt-4o-mini)
# OPENAI_QUIZ_MODEL="gpt-4o-mini"

# Set to true to unlock 30-day daily progress (placeholder for paid tier)
# MEMORIZE_PRO_SUBSCRIBER="true"

# Google OAuth — create a Web client at https://console.cloud.google.com/
# (APIs & Services → Credentials → OAuth client ID). Authorized redirect URIs
# should include http://localhost:3001/api/auth/google/callback for dev and
# https://<your-domain>/api/auth/google/callback for prod.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"

# Upstash Redis — used for edge rate limiting on /api/generate-quiz and the
# Google OAuth start route. If unset, rate limiting is disabled and the app
# behaves exactly as before (graceful degradation), so local dev keeps working
# without these. Provision a free DB at https://console.upstash.com/redis and
# copy the REST URL + REST TOKEN.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Global server-side throttle for expensive quiz generation requests. This is
# a first-pass safety rail, not a full background job queue.
QUIZ_GENERATION_MAX_IN_FLIGHT="40"
QUIZ_GENERATION_SLOT_TTL_SECONDS="180"

# Admin gating for /admin (live ops dashboard) and /api/admin/*. Comma-separated
# list of user emails. If unset, NOBODY is admin and the dashboard is dark.
# Match must be exact (case-insensitive) against the user's account email.
ADMIN_EMAILS=""

# Google Analytics 4 — measurement ID (starts with "G-"). Get it from:
# GA4 → Admin → Data Streams → Web → Measurement ID.
# Leave empty to disable analytics (local dev, staging, etc.).
NEXT_PUBLIC_GA_ID=""
