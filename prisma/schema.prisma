// SQLite for local dev. Switch DATABASE_URL to Postgres without schema changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"   // was "sqlite"
  // Pooled (PgBouncer) URL — used by the running app for queries.
  // Required for serverless/Vercel — eliminates connection exhaustion.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) URL — required by `prisma migrate dev/deploy`
  // because PgBouncer in transaction mode doesn't support the prepared
  // statements/locks Prisma uses for migrations. Falls back to DATABASE_URL
  // if DIRECT_URL isn't set, so local dev keeps working without it.
  directUrl = env("DIRECT_URL")
}

/// Shared “guest” row when the app runs without sign-in (see `lib/guest-user.ts`).
model User {
  id            String    @id @default(cuid())
  name          String?
  nickname      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // replaces CSV
  /// Google account "sub" (stable identifier). Set when the user signs in
  /// via Google OAuth. Nullable so password-only accounts remain valid.
  googleId      String?   @unique
  /// "user" | "admin" — controls access to /admin panel and management APIs.
  /// Bootstrap the first admin via ADMIN_EMAILS env var; after that, admins
  /// can promote other users from the admin panel.
  role            String  @default("user")  // "user" | "admin"
  subscriptionTier String @default("free") // "free" | "pro"
  /// ISO 3166-1 alpha-2 country code captured at registration from Vercel's
  /// x-vercel-ip-country header (e.g. "US", "DE", "BR"). Null for users
  /// created before this field existed or when the header is unavailable.
  country       String?
  createdAt     DateTime  @default(now())

  quizRequests QuizRequest[]
  quizSessions QuizSession[]
}

model QuizRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String?
  summaryText   String   @default("")
  notes         String?
  questionCount Int

  topic         String
  generatedQuiz String
  /// True when the quiz body was the built-in sample (not OpenAI). Hidden from dashboard history.
  usedFallback  Boolean  @default(false)

  questions QuizQuestion[]
  sessions  QuizSession[]

  createdAt DateTime @default(now())

  // Composite index for daily quota queries (userId + usedFallback + createdAt)
  @@index([userId, usedFallback, createdAt])
}

model QuizQuestion {
  id            String      @id @default(cuid())
  quizRequestId String
  quizRequest   QuizRequest @relation(fields: [quizRequestId], references: [id], onDelete: Cascade)

  order        Int
  question     String
  options      String
  correctIndex Int
  explanation  String

  answers QuizAnswer[]
}

model QuizSession {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizRequestId String
  quizRequest   QuizRequest @relation(fields: [quizRequestId], references: [id], onDelete: Cascade)

  score         Int
  percentage    Float
  rankName      String
  questionCount Int
  streakMax     Int         @default(0)
  /// Wall-clock seconds from quiz start to submit (client-reported).
  durationSeconds Int?

  answers QuizAnswer[]

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model QuizAnswer {
  id             String       @id @default(cuid())
  quizSessionId  String
  quizSession    QuizSession  @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  quizQuestionId String
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)

  selectedIndex Int
  isCorrect     Boolean

  @@unique([quizSessionId, quizQuestionId])
}

/// Contact form submissions from /contact. Stored in the DB so they're
/// queryable and don't depend on an external email provider.
model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
